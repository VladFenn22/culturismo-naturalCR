generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nombre   String
  email    String
  whatsapp String

  objetivo       String
  experiencia    String
  disponibilidad String

  lesiones String?
  mensaje  String?

  source String?
  status String  @default("new") // new | contacted | approved | rejected

  inviteToken String?   @unique
  invitedAt   DateTime?

  approvedAt DateTime?
  profiles   Profile[]
}

model Profile {
  id        String   @id // clerk user id
  createdAt DateTime @default(now())

  role   String // coach | client
  email  String
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])
}

model Subscription {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())

  userId               String
  status               String
  stripeCustomerId     String?
  stripeSubscriptionId String?  @unique
  currentPeriodEnd     DateTime?

  @@index([userId])
}

model ClientProfile {
  id             String   @id @default(cuid())
  clerkUserId    String   @unique

  alturaCm       Int?
  pesoKg         Decimal? @db.Decimal(6,2)

  meta           String?
  experiencia    String?
  lesiones       String?
  disponibilidad String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

